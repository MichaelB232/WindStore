generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────

enum Role {
  admin
  customer
}

// ─── Models ──────────────────────────────────────────

model User {
  id           Int        @id @default(autoincrement())
  username     String     @unique
  email        String     @unique
  passwordHash String     @map("password_hash") //Mapping ke nama kolom cammalCase vs snake_case
  role         Role
  createdAt    DateTime   @default(now()) @map("created_at")
  wishlists    Wishlist[]
  orders       Order[]
  cartItems    CartItem[]
  reviews      Review[]

  @@map("users")
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  addedAt   DateTime @default(now()) @map("added_at")

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]

  @@map("categories")
}

model Brand {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String
  products    Product[]

  @@map("brands")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  brandId     Int      @map("brand_id") // FK brand
  slug        String
  categoryId  Int      @map("category_id") // FK Category
  motto       String
  description String
  basePrice   BigInt   @map("base_price")
  badge       String
  specs       Json
  imageUrl    String   @map("image_url")
  stock       Int      @default(0)
  isActive    Boolean  @default(false) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  brand           Brand            @relation(fields: [brandId], references: [id])
  category        Category         @relation(fields: [categoryId], references: [id])
  productImages   ProductImage[]
  productConfigs  ProductConfig[]
  wishlists       Wishlist[]
  orderItems      OrderItem[]
  cartItems       CartItem[]
  productFeatures ProductFeature[]
  reviews         Review[]

  @@map("products")
}

model ProductImage {
  id           Int     @id @default(autoincrement())
  productId    Int     @map("product_id") //FK Products
  imageUrl     String  @map("image_url")
  isPrimary    Boolean @default(false) @map("is_primary")
  displayOrder Int     @map("display_order")

  product Product @relation(fields: [productId], references: [id])

  @@map("product_images")
}

model ProductConfig {
  id            Int     @id @default(autoincrement())
  productId     Int     @map("product_id")
  configName    String  @map("config_name")
  configType    String  @map("config_type")
  priceModifier BigInt  @map("price_modifier")
  isDefault     Boolean @default(false) @map("is_default")
  displayOrder  Int     @map("display_order")

  product    Product     @relation(fields: [productId], references: [id])
  orderItems OrderItem[]
  cartItems  CartItem[]

  @@map("product_configs")
}

model Order {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  totalPrice BigInt   @map("total_price")
  status     String
  createdAt  DateTime @default(now()) @map("created_at")

  user       User        @relation(fields: [userId], references: [id])
  orderItems OrderItem[]
  payments   Payment[]

  @@map("orders")
}

model OrderItem {
  id        Int    @id @default(autoincrement())
  orderId   Int    @map("order_id")
  productId Int    @map("product_id")
  configId  Int?   @map("config_id")
  quantity  Int    @default(1)
  unitPrice BigInt @map("unit_price")

  order         Order          @relation(fields: [orderId], references: [id])
  product       Product        @relation(fields: [productId], references: [id])
  productConfig ProductConfig? @relation(fields: [configId], references: [id])

  @@map("order_items")
}

model CartItem {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  configId  Int      @map("config_id")
  quantity  Int      @default(1)
  addedAt   DateTime @default(now()) @map("added_at")

  user          User          @relation(fields: [userId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])
  productConfig ProductConfig @relation(fields: [configId], references: [id])

  @@unique([userId, productId, configId])
  @@map("cart_items")
}

model ProductFeature {
  id           Int    @id @default(autoincrement())
  productId    Int    @map("product_id")
  title        String
  description  String
  displayOrder Int    @map("display_order")

  product Product @relation(fields: [productId], references: [id])

  @@map("product_features")
}

model PaymentMethod {
  id       Int       @id @default(autoincrement())
  code     String    @unique
  name     String
  type     String
  isActive Boolean   @default(false) @map("is_active")
  payments Payment[]

  @@map("payment_methods")
}

model Payment {
  id              Int      @id @default(autoincrement())
  orderId         Int      @map("order_id")
  paymentMethodId Int      @map("payment_method_id")
  amount          BigInt
  status          String
  transactionId   String?  @unique @map("transaction_id")
  paidAt          DateTime @default(now()) @map("paid_at")
  createdAt       DateTime @default(now()) @map("created_at")

  order         Order         @relation(fields: [orderId], references: [id])
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  @@map("payments")
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  rating    Decimal
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("reviews")
}
